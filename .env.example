TZ=America/Los_Angeles

# FreePBX web UI
HTTP_PORT=8080
HTTPS_PORT=8443

# SIP signaling
SIP_PORT_UDP=5060
SIP_PORT_TCP=5060
PJSIP_PORT_UDP=5160

# RTP media
RTP_PORT_START=18000
RTP_PORT_END=20000

# FreePBX admin bootstrap (tiredofit/freepbx honors these on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Optional (for FreePBX time settings)
TIMEZONE=${TZ}
