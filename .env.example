TZ=America/Los_Angeles

# SIP signaling
SIP_PORT_UDP=5060
SIP_PORT_TCP=5060
PJSIP_PORT_UDP=5160
AMI_PORT=5038
AMI_USERNAME=admin
AMI_PASSWORD=asterisk123

# RTP media
RTP_PORT_START=10000
RTP_PORT_END=20000

# SMS API
SMS_API_PORT=8080
SMS_API_BEARER_TOKEN=change-me
SMS_API_INTERNAL_TOKEN=change-me-internal
SMS_DEVICE=quectel0
MMS_MODEM_PORT=/dev/ttyUSB3
MMS_POLL_INTERVAL_SECONDS=5
MMS_APN=fast.t-mobile.com
MMS_HTTP_PDP_CONTEXT_ID=5
MMS_HTTP_READ_CHUNK_SIZE=4096
# Optional fallback if `quectel show devices` does not expose the line number.
# SMS_FROM_NUMBER=+17203454122
SMS_MEDIA_ROOT=/app/data/media
