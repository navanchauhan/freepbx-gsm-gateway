FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY sms_api/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY sms_api /app/sms_api

RUN mkdir -p /app/data

EXPOSE 8080

CMD ["python", "-m", "sms_api.main"]
